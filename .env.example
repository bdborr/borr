# Public site URL used for metadataBase/OpenGraph. Use your production domain on Vercel.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Turso Database
TURSO_DATABASE_URL=file:borr.db
# TURSO_AUTH_TOKEN=your-turso-auth-token-for-prod

# Optional: Crossref API for community submissions
CROSSREF_API_BASE=https://api.crossref.org

# Admin - generate with: openssl rand -hex 32
ADMIN_SECRET_KEY=your-admin-secret-key

# Optional: NCBI/PubMed polite API identification
NCBI_EMAIL=bdborr@gmail.com
NCBI_API_KEY=
